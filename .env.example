# Cloudify Manager connection
CFY_MANAGER_URL=https://<cloudify-manager-ip-or-dns>
CFY_USERNAME=admin
CFY_PASSWORD=<password>
CFY_TENANT=default_tenant
CFY_API_VERSION=v3.1

# Set true for lab/self-signed Cloudify certificates.
CFY_INSECURE=true

# Default request used by: docker compose up --build
CFY_REQUEST_FILE=requests/hello-dev-install.yaml
